{
  "parserOptions": {
    "ecmaVersion": 2022,
    "sourceType": "module"
  },
  "extends": ["eslint:recommended"],
  "root": true,
  "env": {
    "node": true,
    "jest": true,
    "es2022": true
  },
  "ignorePatterns": [".eslintrc.js"],
  "rules": {
    "no-unused-vars": "off"
  }
}

