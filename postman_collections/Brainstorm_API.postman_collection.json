  "item": [
    {
      "name": "Conversational Assistant",
      "item": [
        {
          "name": "Simple Brainstorm",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Help me brainstorm ideas for a mobile app for pet owners\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/brainstorm/assistant",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "brainstorm",
                "assistant"
              ]
            },
            "description": "Start a new brainstorming session with a simple message. The AI will analyze your idea and generate creative concepts."
          },
          "response": []
        },
