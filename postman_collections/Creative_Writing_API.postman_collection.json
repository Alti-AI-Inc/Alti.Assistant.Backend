    {
      "name": "Conversation Management",
      "item": [
        {
          "name": "Get Conversation History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}",
                "type": "text"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/creative-writing/conversation/:conversationId",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "creative-writing",
                "conversation",
                ":conversationId"
              ],
              "variable": [
                {
                  "key": "conversationId",
                  "value": "{{conversationId}}",
                  "description": "The conversation ID to retrieve"
                }
              ]
            },
            "description": "Retrieve the full conversation history for a creative writing session"
          },
          "response": []
        }
      ]
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    }
  ]
