{
  "info": {
    "name": "Creative Writing API",
    "description": "API endpoints for creative writing assistant - create poems, stories, scripts, song lyrics, and more with AI assistance",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Conversational Assistant",
      "item": [
        {
          "name": "Create a Poem",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Write a romantic poem about moonlight and love\",\n  \"conversationId\": null\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/creative-writing/assistant",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "creative-writing",
                "assistant"
              ]
            },
            "description": "Create a new poem using conversational AI assistant"
          },
          "response": []
        },
        {
