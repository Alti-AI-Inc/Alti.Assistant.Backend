      "name": "Conversational Assistant",
      "item": [
        {
          "name": "Upload and Review Document",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}",
                "type": "text"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "message",
                  "value": "Please review this document for grammar and clarity",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/document-review/assistant",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "document-review",
                "assistant"
              ]
            },
            "description": "Upload a document and request a review using natural language"
          },
          "response": []
        },
