    {
      "name": "Error Test - Invalid Language Code",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Test text\",\n  \"targetLanguage\": \"invalid\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/translation/translate",
          "host": ["{{baseUrl}}"],
          "path": ["translation", "translate"]
        },
        "description": "Test error handling for invalid language codes"
      },
      "response": []
    },
    {
      "name": "Error Test - Missing Required Fields",
      "request": {
        "method": "POST",
