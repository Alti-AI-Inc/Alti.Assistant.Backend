            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Test text\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/translation/translate",
          "host": ["{{baseUrl}}"],
          "path": ["translation", "translate"]
        },
        "description": "Test validation for missing target language"
      },
      "response": []
    }
  ],
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    }
  ]
}
