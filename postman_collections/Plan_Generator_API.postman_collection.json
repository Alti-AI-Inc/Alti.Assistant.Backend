        {
          "name": "Get Conversation History",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{auth_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/plan-generator/conversation/{{conversationId}}",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "conversation", "{{conversationId}}"]
            },
            "description": "Retrieve full conversation history including all messages, analysis, brainstorm, and generated plan."
          },
          "response": []
        }
