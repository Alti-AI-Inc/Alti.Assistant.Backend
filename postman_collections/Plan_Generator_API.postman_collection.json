              "raw": "{\n  \"idea\": \"Redesign company website with modern UI and improved user experience\",\n  \"planType\": \"project_plan\",\n  \"complexity\": \"simple\",\n  \"planDepth\": \"quick\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/generate",
