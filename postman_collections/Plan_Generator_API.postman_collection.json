{
  "info": {
    "_postman_id": "plan-generator-collection-2024",
    "name": "Plan Generator API",
    "description": "Comprehensive API collection for the Plan Generator module - AI-powered planning assistant that transforms ideas into actionable plans",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Conversational Planning",
      "item": [
        {
          "name": "Start New Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I want to launch a food delivery app for small restaurants\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/assistant",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "assistant"]
            },
            "description": "Start a new planning conversation. AI will analyze your idea and may ask clarifying questions."
          },
          "response": []
        },
        {
          "name": "Continue Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"The target market is urban areas with 500+ restaurants. Budget is $50,000 and timeline is 6 months\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/assistant",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "assistant"]
            },
            "description": "Continue an existing conversation with more details or refinement requests."
          },
          "response": []
        },
        {
          "name": "Conversational with File Upload",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "message",
                  "value": "Create a plan based on the attached business requirements document",
                  "type": "text"
                },
                {
                  "key": "file",
                  "type": "file",
                  "src": "/path/to/your/document.pdf"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/assistant",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "assistant"]
            },
            "description": "Upload a document (PDF, DOCX, TXT) to provide additional context for plan generation."
          },
          "response": []
        },
        {
          "name": "Request Refinement",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Can you make the timeline more aggressive and add more detail to the marketing strategy?\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/assistant",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "assistant"]
            },
            "description": "Request refinements to specific sections of your plan."
          },
          "response": []
        },
        {
          "name": "Get Alternative Approaches",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"What are some alternative approaches to this plan?\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/assistant",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "assistant"]
            },
            "description": "Request alternative strategies and approaches for your plan."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Direct Plan Generation",
      "item": [
        {
          "name": "Generate Business Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Create a sustainable fashion e-commerce platform that connects eco-friendly designers with conscious consumers\",\n  \"planType\": \"business_plan\",\n  \"complexity\": \"complex\",\n  \"planDepth\": \"comprehensive\",\n  \"domains\": [\"business\", \"marketing\", \"technical\"],\n  \"constraints\": {\n    \"budget\": 100000,\n    \"timeline\": \"12 months\",\n    \"teamSize\": 8\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/generate",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "generate"]
            },
            "description": "Generate a complete business plan with all parameters specified."
          },
          "response": []
        },
        {
          "name": "Generate Product Launch Plan",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
