      ]
    },
    {
      "name": "Brainstorming",
      "item": [
        {
          "name": "Brainstorm with All Aspects",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Create an AI-powered tutoring platform for high school students that provides personalized learning paths\",\n  \"aspects\": [\n    \"swot_analysis\",\n    \"market_analysis\",\n    \"competitive_landscape\",\n    \"resource_needs\",\n    \"risk_assessment\",\n    \"financial_projections\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/brainstorm",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "brainstorm"]
            },
            "description": "Generate comprehensive brainstorming insights for an idea."
          },
          "response": []
        },
