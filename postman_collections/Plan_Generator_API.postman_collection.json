            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launch a mobile fitness app with AI-powered workout recommendations and social features\",\n  \"planType\": \"product_launch\",\n  \"complexity\": \"moderate\",\n  \"planDepth\": \"standard\",\n  \"domains\": [\"technical\", \"marketing\", \"design\"],\n  \"constraints\": {\n    \"budget\": 50000,\n    \"timeline\": \"6 months\",\n    \"teamSize\": 5\n  },\n  \"brainstormAspects\": [\n    \"swot_analysis\",\n    \"market_analysis\",\n    \"technical_feasibility\",\n    \"financial_projections\"\n  ]\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/generate",
              "host": ["{{base_url}}"],
              "path": ["plan-generator", "generate"]
            },
            "description": "Generate a product launch plan with specific brainstorming aspects."
          },
          "response": []
        },
