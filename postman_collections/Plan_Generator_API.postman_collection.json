              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Create a blockchain-based supply chain tracking system for pharmaceutical companies\",\n  \"aspects\": [\n    \"technical_feasibility\",\n    \"market_analysis\",\n    \"financial_projections\"\n  ],\n  \"context\": {\n    \"industry\": \"Pharmaceutical & Healthcare\",\n    \"targetMarket\": \"Mid to large pharmaceutical companies\",\n    \"budget\": 200000,\n    \"timeline\": \"18 months\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/brainstorm",
