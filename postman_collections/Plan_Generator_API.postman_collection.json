          "name": "SWOT Analysis Only",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launch a subscription box service for organic baby products\",\n  \"aspects\": [\"swot_analysis\"]\n}"
            },
            "url": {
              "raw": "{{base_url}}/plan-generator/brainstorm",
