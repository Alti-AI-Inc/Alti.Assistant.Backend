        "body": {
          "mode": "formdata",
          "formdata": [
            {
              "key": "message",
              "value": "I need a freelance contract for a graphic designer working on a logo design project",
              "type": "text"
            }
          ]
        },
        "url": {
          "raw": "{{baseUrl}}/legal-contract/assistant",
