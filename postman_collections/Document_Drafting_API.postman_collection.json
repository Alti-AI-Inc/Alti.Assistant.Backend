                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Create a business proposal for implementing a new CRM system for the sales team. Include benefits, timeline, and cost analysis.\",\n  \"documentType\": \"proposal\",\n  \"outputFormat\": \"pdf\",\n  \"tone\": \"professional\",\n  \"length\": \"long\",\n  \"wordCount\": 2000,\n  \"includeTitle\": true,\n  \"includeDate\": true,\n  \"language\": \"en\",\n  \"additionalInstructions\": \"Include an executive summary at the beginning\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/generate",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "generate"
              ]
            },
            "description": "Generate a business proposal with all parameters specified"
          },
          "response": []
        },
