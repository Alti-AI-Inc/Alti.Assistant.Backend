        {
          "name": "Start New Document Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"I need to write a professional business proposal for a new software project\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/documents/assistant",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "documents",
                "assistant"
              ]
            },
            "description": "Start a new conversational document drafting session"
          },
          "response": []
        },
