{
  "info": {
    "name": "Enhanced Image API",
    "_postman_id": "enhanced-image-api-v1",
    "description": "Complete API collection for Enhanced Image module with conversation-based image generation and editing",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "authToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "conversationId",
      "value": "",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Image Generation",
      "item": [
        {
          "name": "Generate Image (Guest)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.conversationId) {",
                  "        pm.collectionVariables.set('conversationId', jsonData.data.conversationId);",
                  "    }",
                  "    if (jsonData.data && jsonData.data.userId) {",
                  "        pm.collectionVariables.set('userId', jsonData.data.userId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"A serene mountain landscape at sunset with a lake reflection, photorealistic style\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enhanced-image/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "enhanced-image",
                "generate"
              ]
            },
            "description": "Generate an image as a guest user without authentication. Creates a new conversation automatically."
          },
          "response": []
        },
        {
          "name": "Generate Image (Authenticated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.conversationId) {",
                  "        pm.collectionVariables.set('conversationId', jsonData.data.conversationId);",
                  "    }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"A futuristic city skyline at night with neon lights, cyberpunk style\",\n  \"aspectRatio\": \"16:9\",\n  \"negativePrompt\": \"blurry, low quality\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enhanced-image/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "enhanced-image",
                "generate"
              ]
            },
            "description": "Generate an image with authentication. Checks subscription limits."
          },
          "response": []
        },
        {
          "name": "Generate Image (Continue Conversation)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Add more vibrant colors and increase the saturation\",\n  \"conversationId\": \"{{conversationId}}\",\n  \"userId\": \"{{userId}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enhanced-image/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "enhanced-image",
                "generate"
              ]
            },
            "description": "Continue an existing conversation to generate a contextually-aware image."
          },
          "response": []
        },
        {
          "name": "Generate from Conversation History",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"conversationId\": \"{{conversationId}}\",\n  \"aspectRatio\": \"16:9\",\n  \"negativePrompt\": \"blurry, low quality\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enhanced-image/generate-from-conversation",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "enhanced-image",
                "generate-from-conversation"
              ]
            },
            "description": "Generate an image using the entire conversation history to build an enhanced prompt automatically."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Image Editing",
      "item": [
        {
          "name": "Edit Image (Guest)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    const jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.conversationId) {",
                  "        pm.collectionVariables.set('conversationId', jsonData.data.conversationId);",
                  "    }",
                  "    if (jsonData.data && jsonData.data.userId) {",
                  "        pm.collectionVariables.set('userId', jsonData.data.userId);",
                  "    }",
                  "}"
