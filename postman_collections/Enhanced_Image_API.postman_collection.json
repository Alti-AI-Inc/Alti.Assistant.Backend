            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Add a rainbow to the sky\",\n  \"imageBase64\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enhanced-image/edit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "enhanced-image",
                "edit"
              ]
            },
            "description": "Edit an existing image by providing base64 encoded image and edit instructions."
          },
          "response": []
        },
        {
          "name": "Edit Image (Authenticated)",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{authToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prompt\": \"Make the image brighter and add more contrast\",\n  \"imageBase64\": \"data:image/png;base64,iVBORw0KGgoAAAANSUhEUgAAAAEAAAABCAYAAAAfFcSJAAAADUlEQVR42mNk+M9QDwADhgGAWjR9awAAAABJRU5ErkJggg==\",\n  \"conversationId\": \"{{conversationId}}\",\n  \"aspectRatio\": \"16:9\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/enhanced-image/edit",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "enhanced-image",
                "edit"
              ]
            },
            "description": "Edit an image with authentication and continue an existing conversation."
          },
          "response": []
        }
      ]
    },
