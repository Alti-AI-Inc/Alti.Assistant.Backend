{
  "info": {
    "name": "Tenant Management API",
    "description": "Complete test suite for tenant CRUD operations, member management, and tenant context",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "tenant-mgmt-001"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1",
      "type": "string"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
