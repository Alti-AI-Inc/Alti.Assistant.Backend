    {
      "name": "2. Tenant CRUD",
      "item": [
        {
          "name": "TC-003: Check Subdomain Availability (Available)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Subdomain is available', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.available).to.be.true;",
                  "    pm.expect(jsonData.data.subdomain).to.equal('test-workspace');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "auth": {
              "type": "noauth"
            },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/tenant/check-subdomain?subdomain=test-workspace",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "tenant",
                "check-subdomain"
              ],
              "query": [
                {
                  "key": "subdomain",
                  "value": "test-workspace"
                }
              ]
            }
          }
        },
        {
          "name": "TC-004: Create Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Tenant created with correct data', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data.plan).to.equal('free');",
                  "    pm.expect(jsonData.data.status).to.equal('trial');",
                  "    pm.expect(jsonData.data.subdomain).to.equal('test-workspace');",
                  "    pm.environment.set('tenantId', jsonData.data.id);",
                  "});",
                  "",
                  "pm.test('Subdomain is returned', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('subdomain');",
                  "});",
                  "",
                  "pm.test('New access token with tenantId is returned', function () {",
                  "    var jsonData = pm.response.json();",
                  "    pm.expect(jsonData.data).to.have.property('accessToken');",
                  "    pm.environment.set('ownerToken', jsonData.data.accessToken);",
                  "});",
                  "",
                  "pm.test('Token contains tenantId', function () {",
                  "    var jsonData = pm.response.json();",
                  "    var token = jsonData.data.accessToken;",
                  "    var payload = JSON.parse(atob(token.split('.')[1]));",
                  "    pm.expect(payload).to.have.property('tenantId');",
                  "    pm.expect(payload.tenantId).to.equal(jsonData.data.id);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/tenant/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test Workspace\",\n  \"slug\": \"test-workspace\",\n  \"subdomain\": \"test-workspace\"\n}"
            }
          }
        },
