              "raw": "{\n  \"content\": \"Monthly sales data: January: $50000, February: $55000, March: $60000, April: $58000, May: $62000, June: $65000\",\n  \"title\": \"Sales Data Report\",\n  \"reportType\": \"financial\",\n  \"outputFormat\": \"xlsx\",\n  \"tone\": \"formal\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/generate",
              "host": [
                "{{baseUrl}}"
