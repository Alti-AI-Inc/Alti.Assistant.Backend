              "mode": "formdata",
              "formdata": [
                {
                  "key": "message",
                  "value": "Analyze these files and create a detailed report",
                  "type": "text"
                },
                {
                  "key": "files",
                  "type": "file",
                  "src": []
                },
                {
                  "key": "outputFormat",
                  "value": "pdf",
                  "type": "text"
                },
                {
                  "key": "reportType",
                  "value": "analytical",
                  "type": "text"
                }
              ]
            },
            "url": {
