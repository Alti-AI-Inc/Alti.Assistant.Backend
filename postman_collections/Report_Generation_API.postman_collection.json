        },
        {
          "name": "Continue Conversation",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Make it more detailed with charts\",\n  \"conversationId\": \"{{conversationId}}\"\n}"
