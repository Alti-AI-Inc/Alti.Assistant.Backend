    {
      "name": "Direct Generation",
      "item": [
        {
          "name": "Generate PDF Report",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Our company achieved significant growth in Q4 2024. Revenue increased by 35% compared to Q3. Key drivers included new product launches, market expansion in Asia, and improved customer retention rates. The sales team exceeded targets by 20%.\",\n  \"title\": \"Q4 2024 Business Performance Report\",\n  \"reportType\": \"business\",\n  \"outputFormat\": \"pdf\",\n  \"tone\": \"professional\",\n  \"includeTitlePage\": true,\n  \"includeTableOfContents\": true,\n  \"includeExecutiveSummary\": true,\n  \"sections\": [\n    \"title_page\",\n    \"executive_summary\",\n    \"introduction\",\n    \"findings\",\n    \"analysis\",\n    \"recommendations\",\n    \"conclusion\"\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/generate",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reports",
                "generate"
              ]
            },
            "description": "Generate a PDF report directly"
          }
        },
