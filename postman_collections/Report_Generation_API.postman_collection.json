    {
      "name": "Conversational Assistant",
      "item": [
        {
          "name": "Text-Only Report Request",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"message\": \"Create a comprehensive sales report for Q4 2024\",\n  \"outputFormat\": \"pdf\",\n  \"reportType\": \"analytical\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/reports/assistant",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "reports",
                "assistant"
              ]
            },
            "description": "Generate a report from text message only"
          }
        },
        {
          "name": "With File Upload",
          "request": {
            "method": "POST",
            "header": [],
