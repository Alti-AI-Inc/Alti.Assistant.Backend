          "number": "13"
        },
        {
          "type": "char",
          "marker": "w",
          "strong": "H859",
          "content": [
            "But as for you"
          ]
        },
        ", ",
        {
          "type": "char",
          "marker": "w",
          "strong": "H1980",
          "content": [
            "go on your way"
          ]
        },
        {
          "type": "char",
          "marker": "w",
          "strong": "H7093",
          "content": [
            "until the end"
          ]
        },
        ". ",
        {
          "type": "char",
          "marker": "w",
          "strong": "H5117",
          "content": [
            "You will rest"
          ]
        },
        ", ",
        {
          "type": "char",
          "marker": "w",
          "strong": "H5975",
          "content": [
            "and then you will arise"
          ]
        },
        {
          "type": "char",
          "marker": "w",
          "strong": "H1486",
          "content": [
            "to your inheritance"
          ]
        },
        {
          "type": "char",
          "marker": "w",
