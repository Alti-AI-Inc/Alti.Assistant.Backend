# Presentation Module Environment Variables

# Presenton API Configuration
# Get your API key from: https://presenton.ai/account
PRESENTON_API_URL=http://localhost:5000
PRESENTON_API_KEY=sk-presenton-xxxxx

# Required for AI conversation analysis (already in your config)
# GEMINI_API_KEY=your-gemini-api-key

# Optional: Enable/disable features
ENABLE_PRESENTATION_MODULE=true
